# Varsel — environment variables. Copy to .env.local (gitignored) and fill in.
# Next.js loads .env.local automatically; it is never committed.

# Anthropic API key for the live Impact Room AI route (/api/ai/impact).
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_, never expose to the client.
ANTHROPIC_API_KEY=

# Force the cached golden response instead of a live Claude call (the presenter
# says "offline mode" out loud). The route ALSO falls back to offline
# automatically whenever ANTHROPIC_API_KEY is absent — so the demo never depends
# on conference/client wifi. Set to "offline" to pin it; unset for live.
DEMO_MODE=offline

# Supabase (EU project "Jensen", eu-west-1) for the careers feed.
# Read path (server route /api/feeds/careers) — anon key is RLS-gated public read,
# safe to expose. The route falls back to the cached snapshot if these are unset.
SUPABASE_URL=https://jzlphajunfrqvpogzsiz.supabase.co
SUPABASE_ANON_KEY=

# Write path (scripts/crawl-careers.ts only) — SERVICE ROLE key, a server-side
# SECRET that bypasses RLS to insert snapshots. Never expose to the client.
# From Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override the SuccessFactors jobs endpoint the scraper hits.
# CAREERS_JOBS_URL=https://careers.st-group.com/...
